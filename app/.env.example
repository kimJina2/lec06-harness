# 이 파일은 git에 커밋 OK — 실제 값이 아닌 placeholder만 들어가야 한다.
# 실제 키는 `cp .env.example .env` 후 .env에만 채워 넣을 것.
# .env는 .gitignore에 의해 자동으로 제외됨.

APP_ENV=development

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Groq (https://console.groq.com/keys) — MCP 실험에서 사용
GROQ_API_KEY=gsk_REPLACE_ME

# (선택) Kaggle vLLM Cloudflare Tunnel URL
# VLLM_BASE_URL=https://xxx-yyy.trycloudflare.com/v1
